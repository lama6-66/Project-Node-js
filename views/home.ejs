

   
        <table style="width: 95%;"
          class="mt-5 mx-auto  table table-dark table-striped  table-bordered border-primary text-center  ">
          <thead>
            <tr >
              <th scope="col">#</th>
              <th scope="col">Full Name</th>
              <th scope="col">Gender</th>
              <th scope="col">Country</th>
              <th scope="col">Age</th>
              <th scope="col">Last Updated</th>
              <th scope="col">Action</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <% users.forEach(function(item,index){ %>
              <th scope="row"><%= index+1 %></th>
              <td><%= item.First_Name %>  <%= item.Last_Name %></td>
              <td><%= item.gender %></td>
              <td><%= item.Country %></td>
              <td><%= item.Age %></td>
              <td><%= item.display_date%></td>
              
              
              <td>
                <div
                  class="d-flex justify-content-center align-items-center gap-2">
                  <a href="/view" data-bs-toggle="modal" data-bs-target="#usermodal" data-bs-title="Default modal" ><i class="bi bi-arrows-fullscreen" ></i></a>
                  <a href=""><i class="bi bi-pencil"></i></a>
                  <button  type="button" class="btn p-0 border-0 "><i
                      class="bi bi-person-x text-danger"></i></button>
                </div>
              </td>
            </tr>
            <%  }); %>

          </tbody>
        </table>

        <div class="modal" id="usermodal" tabindex="-1">
          <div class="modal-dialog modal-lg ">
            <div class="modal-content bg-dark text-light border-secondary">
              <div class="modal-hedar border-secondary ">
                <h6>User Data</h6>
                <button type="button" class="btn-close btn-close-white " data-bs-dismiss="modal"></button>
              </div>

              <div class="modal-body">
                <%- include("view") %>
              </div>

            </div>

          </div>

        </div>
    