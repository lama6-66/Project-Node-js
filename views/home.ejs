<head>
  <link rel="stylesheet" href="/home.css">
</head>

<div class="table-responsive-custom">

  <table
    class="mt-5 mx-auto table table-dark table-striped table-bordered border-primary text-center">
    <thead>
      <tr>
        <th scope="col">#</th>
        <th scope="col">Name</th> <th scope="col">Email</th>
        <th scope="col">Gender</th>
        <th scope="col">Country</th>
        <th scope="col">Age</th>
        <th scope="col">Phone</th>
        <th scope="col">Date</th> <th scope="col">Action</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(function(item, index){ %>
      <tr>
        <td data-label="#"> <%= index+1 %> </td>
        <td data-label="Name"> <%= item.First_Name %> <%= item.Last_Name %>
        </td>
        <td data-label="Email"> <%= item.Email %> </td>
        <td data-label="Gender"> <%= item.gender %> </td>
        <td data-label="Country"> <%= item.Country %> </td>
        <td data-label="Age"> <%= item.Age %> </td>
        <td data-label="Phone"> <%= item.Mobile_Number %> </td>
        <td data-label="Date"> <%= item.display_date %> </td>

        <td data-label="Action">
          <div class="d-flex justify-content-center align-items-center gap-2">
            <a href="/edit/<%= item.id %>"><i class="bi bi-pencil"></i></a>
            <form action="/deleteUser/<%= item.id %>" method="POST"
              style="display:inline;"
              onsubmit="return confirm('هل أنتِ متأكدة؟');">
              <button type="submit"
                style="background: none; border: none; padding: 0; cursor: pointer;">
                <i class="bi bi-person-x text-danger"></i>
              </button>
            </form>
          </div>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>

